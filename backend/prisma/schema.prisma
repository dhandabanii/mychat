generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum Role {
  USER
  SUPER_ADMIN // For overall app admin if needed later
}

enum GroupRole {
  MEMBER
  ADMIN
  SUPER_ADMIN
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
  VOICE
  DOCUMENT
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model User {
  id                String    @id @default(uuid())
  phoneNumber       String?   @unique
  email             String?   @unique
  passwordHash      String
  fullName          String
  profilePictureUrl String?
  bio               String?   @default("Hey there! I am using this app.")
  publicKey         String?   // For E2EE key exchange
  lastSeen          DateTime  @default(now())
  isOnline          Boolean   @default(false)
  accountStatus     AccountStatus @default(ACTIVE)
  role              Role      @default(USER)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions          Session[]
  sentMessages      Message[]
  contacts          Contact[] @relation("UserContacts")
  contactedBy       Contact[] @relation("ContactUsers")
  groupMemberships  GroupMember[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  deviceId     String   @unique
  refreshToken String?
  fcmToken     String?
  ipAddress    String?
  lastActive   DateTime @default(now())
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id            String   @id @default(uuid())
  userId        String
  contactUserId String
  isBlocked     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contactUser   User     @relation("ContactUsers", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([userId, contactUserId])
}

model Conversation {
  id               String           @id @default(uuid())
  type             ConversationType
  groupName        String?
  groupDescription String?
  groupAvatarUrl   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  messages         Message[]
  participants     GroupMember[]
}

model GroupMember {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  role           GroupRole    @default(MEMBER)
  joinedAt       DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id               String        @id @default(uuid())
  conversationId   String
  senderId         String
  encryptedPayload String        // The actual encrypted message
  mediaUrl         String?       // Encrypted media URL
  type             MessageType   @default(TEXT)
  status           MessageStatus @default(SENT)
  createdAt        DateTime      @default(now())

  conversation     Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
}
